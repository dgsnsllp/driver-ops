{
  "expo": {
    "name": "Driver Ops",
    "slug": "driver-ops",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dgsnsllp.driverops"
    },
    "android": {
      "package": "com.dgsnsllp.driverops",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bf85baf2-4283-4959-9727-e476972be7c9"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Araç QR kodunu taramak için kamera izni gerekiyor."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "QR kodunuzu cihaz galerisine kaydetmek için galeri erişim izni gerekiyor.",
          "savePhotosPermission": "QR kodunuzu galeriye kaydetmek için izin gerekiyor."
        }
      ]
    ]
  }
}
